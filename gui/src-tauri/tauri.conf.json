{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DoH Proxy",
  "version": "0.1.0",
  "identifier": "com.doh-proxy.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DoH Proxy",
        "width": 900,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
